{
  "name": "@slorenzot/memento-cli",
  "version": "0.1.2",
  "description": "CLI interface for Memento",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "memento": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun tsc --declaration --declarationMap --emitDeclarationOnly --outDir ./dist",
    "test": "bun test",
    "typecheck": "bun tsc --noEmit"
  },
  "dependencies": {
    "@slorenzot/memento-core": "^0.1.2",
    "commander": "^12.0.0",
    "ink": "^4.4.1",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "zod": "^3.22.4",
    "dotenv": "^16.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "bun-types": "^1.3.11"
  }
}
