# Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET=development-secret-change-in-production

# Base URL of the web application
AUTH_URL=http://localhost:8086
NEXTAUTH_URL=http://localhost:8086

# Auth database path (default: ./data/auth.db)
# AUTH_DB_PATH=./data/auth.db

# Memento core database path (default: ./data/memento.db)
# MEMENTO_DB_PATH=./data/memento.db
